<group name="custom_sysmon_group">

  <rule id="100500" level="0">
    <decoded_as>windows_eventchannel</decoded_as>
    <field name="win.system.providerName">^Microsoft-Windows-Sysmon$</field>
    <description>Sysmon Event Base Log</description>
  </rule>

  <rule id="100601" level="5">
    <if_sid>100500</if_sid>
    <field name="win.system.eventID">^1$</field>
    <description>Sysmon - Processo Criado: $(win.eventdata.originalFileName)</description>
  </rule>

  <rule id="100603" level="5">
    <if_sid>100500</if_sid>
    <field name="win.system.eventID">^3$</field>
    <description>Sysmon - Conexão de Rede: $(win.eventdata.image)</description>
  </rule>

  <rule id="100622" level="5">
    <if_sid>100500</if_sid>
    <field name="win.system.eventID">^22$</field>
    <description>Sysmon - Consulta DNS: $(win.eventdata.queryName)</description>
  </rule>

  <rule id="100608" level="5">
    <if_sid>100500</if_sid>
    <field name="win.system.eventID">^8$</field>
    <description>Sysmon - CreateRemoteThread (Injeção de Código)</description>
  </rule>

</group>
